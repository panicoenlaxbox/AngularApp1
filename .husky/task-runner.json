{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "welcome-message-example",
         "command": "bash",
         "args": [ "-c", "echo Husky.Net is awesome!" ],
         "windows": {
            "command": "cmd",
            "args": ["/c", "echo Husky.Net is awesome!" ]
         }
      },
      {
         "name": "dotnet-format",
         "command": "dotnet",
         "args": [
            "format",
            ".\\Server\\WebApplication1.slnx",
            "--no-restore",
            "--verify-no-changes",
            "--verbosity",
            "detailed",
            "--include",
            "${staged}"
         ]
      }
   ]
}
