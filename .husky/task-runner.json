{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "editorconfig-checker",
         "command": "editorconfig-checker"
      },
      {
         "name": "dotnet-format",
         "command": "dotnet",
         "args": [
            "format",
            "./Server/WebApplication1.slnx",
            "--no-restore",
            "--verify-no-changes",
            "--verbosity",
            "detailed",
            "--include",
            "${staged}"
         ]
      }
   ]
}
